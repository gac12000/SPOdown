{
  "name": "RIPPR · Music Downloader",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "forwardPorts": [5000],
  "portsAttributes": {
    "5000": {
      "label": "RIPPR Web",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "pip install flask spotdl yt-dlp && sudo apt-get install -y ffmpeg -q",
  "remoteEnv": {
    "PYTHONUNBUFFERED": "1"
  }
}
